# Apps Script web app (existing Bistro Cloud CRM API) — set the real /exec URL in Vercel env
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# Admin role password for gated Apps Script actions — set the real value in Vercel env
APPS_SCRIPT_ADMIN_PASSWORD=changeme
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
# Instapay bank details shown to the customer (free text)
INSTAPAY_DETAILS=Bistro Cloud — Bank: XXX, Account: 000000000000, Name: Bistro Cloud
# Allowed browser origin for CORS
ALLOWED_ORIGIN=https://bistro-cloud.com
